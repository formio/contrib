<div class="cc-grid cc-grid--cols-{{ ctx.cardColumnsSmall }}"
     ref="cardGrid"
     data-cols="{{ ctx.cardColumns }}"
     data-cols-small="{{ ctx.cardColumnsSmall }}"
     data-image-fit="{{ ctx.imageFit }}">
  {% ctx.items.forEach(function(item) {
       var selected = ctx.isSelected(item.value);
       var hasImage = !!item.imageUrl;
       var serialized = ctx.serializeValue(item.value);
       var label = item.label || '';
       var hidden = !item._visible;
  %}
    <div class="cc-card{% if (selected) { %} cc-card--selected{% } %}{% if (!hasImage) { %} cc-card--text-only{% } %}{% if (hidden) { %} cc-card--hidden{% } %}"
         ref="wrapper"
         data-value="{{ serialized }}">
      <input type="radio"
             ref="input"
             class="cc-card__input"
             {{ ctx.inputAttrs }}
             value="{{ serialized }}"
             id="{{ ctx.instanceId }}-{{ ctx.componentKey }}-{{ serialized }}"
             {% if (selected) { %}checked{% } %}
             role="radio">
      {% if (hasImage) { %}
        <div class="cc-card__image-wrap">
          <img src="{{ item.imageUrl }}" alt="{{ label }}">
        </div>
      {% } %}
      <div class="cc-card__label">{{ label }}</div>
    </div>
  {% }); %}
</div>

{% if (ctx.totalPages > 1) { %}
  <div class="cc-pagination">
    <button type="button" ref="prevButton"{% if (ctx.currentPage <= 0) { %} disabled{% } %}>
      {{ ctx.chevronLeft }}Prev
    </button>
    <span class="cc-pagination__indicator" ref="pageIndicator">
      {{ ctx.currentPage + 1 }} / {{ ctx.totalPages }}
    </span>
    <button type="button" ref="nextButton"{% if (ctx.currentPage >= ctx.totalPages - 1) { %} disabled{% } %}>
      Next{{ ctx.chevronRight }}
    </button>
  </div>
{% } %}
